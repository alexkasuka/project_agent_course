# Secrets and local configuration
.env
.env.*
!.env.example

# Python environments
.venv/
venv/
env/
ENV/

# Python caches and test artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# OS/editor noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# GitHub/local CLI metadata
.github/CODEOWNERS.local
.github/*.local.yml
.github/*.local.yaml
.gh/


# User assignments: keep folder, ignore private homework files
assignments/*
!assignments/.gitkeep

# Course materials: keep public demo materials, ignore private course files
course_materials/*
!course_materials/.gitkeep
!course_materials/demo_*.md
!course_materials/demo_*.ipynb

# Generated knowledge base
data/*
!data/.gitkeep

# Generated homework results
outputs/*
!outputs/.gitkeep
